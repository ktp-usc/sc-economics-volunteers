generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// teaching workshop or general event
enum EventType {
  Teaching
  Workshop
  Event
}

// grade band we're targeting
enum AgeGroup {
  K_5   @map("K-5")
  G6_8  @map("6-8")
  G9_12 @map("9-12")
}

// what kind of background the volunteer should have
enum Expertise {
  Finance
  Teaching
  Technology
  Business
  Outreach
}

// sc cities we run events in
enum City {
  Columbia
  Greenville
  Charleston
  Spartanburg
  Rock_Hill    @map("Rock Hill")
  Aiken
  Myrtle_Beach @map("Myrtle Beach")
}

// where an application sits in review
enum ApplicationStatus {
  pending
  approved
  denied
}

// admin can manage events volunteers can sign up
enum Role {
  admin
  volunteer
}

// a registered user — volunteer or admin
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  role      Role     @default(volunteer)
  createdAt DateTime @default(now())
}

// an event posted by admin
model Event {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  venue       String
  city        City
  type        EventType
  ageGroup    AgeGroup
  expertise   Expertise
  date        DateTime      @db.Date
  spotsTotal  Int
  spotsFilled Int           @default(0)
  createdAt   DateTime      @default(now())
  signups     EventSignup[]
}

// a volunteers signup for one specific event
model EventSignup {
  id          Int      @id @default(autoincrement())
  eventId     Int
  userId      Int
  why         String
  fromTime    String
  toTime      String
  certificate Boolean
  expertise   String?
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id])
}

// the application form a new volunteer submits
// city is free text here they can live anywhere
model Application {
  id              Int               @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String
  phone           String
  street          String
  city            String
  state           String            @default("South Carolina")
  zip             String
  availableDays   String[]
  skills          String
  experience      String?
  motivation      String
  backgroundCheck Boolean           @default(false)
  dataConsent     Boolean           @default(false)
  status          ApplicationStatus @default(pending)
  appliedAt       DateTime          @default(now())
}
