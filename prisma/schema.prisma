generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  Teaching
  Workshop
  Event
}

enum AgeGroup {
  K_5   @map("K-5")
  G6_8  @map("6-8")
  G9_12 @map("9-12")
}

enum Expertise {
  Finance
  Teaching
  Technology
  Business
  Outreach
}

enum City {
  Columbia
  Greenville
  Charleston
  Spartanburg
  Rock_Hill    @map("Rock Hill")
  Aiken
  Myrtle_Beach @map("Myrtle Beach")
}

enum ApplicationStatus {
  pending
  approved
  denied
}

enum Role {
  admin
  manager
  volunteer
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  role      Role     @default(volunteer)
  sessionToken String?  @unique
  createdAt DateTime @default(now())
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String
  description String
  venue       String
  city        City
  type        EventType
  ageGroup    AgeGroup
  expertise   Expertise
  date        DateTime        @db.Date
  spotsTotal  Int
  spotsFilled Int             @default(0)
  createdAt   DateTime        @default(now())
  signups     EventSignup[]
  hoursLogs   VolunteerHours[]
}

model EventSignup {
  id          Int      @id @default(autoincrement())
  eventId     Int
  userId      String
  why         String
  fromTime    String
  toTime      String
  certificate Boolean
  expertise   String?
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id])
}

// Hours logged by an admin for a volunteer completing an event
model VolunteerHours {
  id          Int      @id @default(autoincrement())
  userId      String   // Neon Auth user ID
  userEmail   String   // denormalized for easy display without a join
  eventId     Int
  hours       Float
  note        String?
  loggedAt    DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id])
}

model Application {
  id              Int               @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String
  phone           String
  street          String
  city            String
  state           String            @default("South Carolina")
  zip             String
  availableDays   String[]
  skills          String
  experience      String?
  motivation      String
  backgroundCheck Boolean           @default(false)
  dataConsent     Boolean           @default(false)
  status          ApplicationStatus @default(pending)
  appliedAt       DateTime          @default(now())
}
